{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "kubernetes": {
    "managerFilePatterns": [
      "/clusters/.+\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/clusters/.+\\.yaml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": ["kubernetes", "helm-values"],
      "automerge": false
    }
  ]
}
